# Token bot Telegram, lấy từ @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Access token Genius API, lấy từ https://genius.com/api-clients (tạo app -> Client Access Token)
GENIUS_ACCESS_TOKEN=your_genius_client_access_token

# Chuỗi bí mật để bảo vệ webhook (tùy đặt, ví dụ chuỗi ngẫu nhiên dài).
# Telegram sẽ gửi kèm header X-Telegram-Bot-Api-Secret-Token = giá trị này.
WEBHOOK_SECRET=mot_chuoi_bi_mat_ngau_nhien

# URL công khai của deployment (chỉ dùng khi chạy script set-webhook)
# Ví dụ: https://lyrics-bot.vercel.app
PUBLIC_URL=https://your-app.vercel.app

# (Tùy chọn) ScraperAPI key để vượt Cloudflare khi scrape Genius từ IP datacenter.
# Đăng ký free tại https://www.scraperapi.com/ — 5000 request/tháng.
SCRAPERAPI_KEY=your_scraperapi_key

# PostgreSQL connection string — tạo database tại https://dashboard.render.com/new/postgresql
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Spotify App credentials — tạo app tại https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
