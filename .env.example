# Token bot Telegram, lấy từ @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Access token Genius API, lấy từ https://genius.com/api-clients (tạo app -> Client Access Token)
GENIUS_ACCESS_TOKEN=your_genius_client_access_token

# Chuỗi bí mật để bảo vệ webhook (tùy đặt, ví dụ chuỗi ngẫu nhiên dài).
# Telegram sẽ gửi kèm header X-Telegram-Bot-Api-Secret-Token = giá trị này.
WEBHOOK_SECRET=mot_chuoi_bi_mat_ngau_nhien

# URL công khai của deployment Vercel (chỉ dùng khi chạy script set-webhook)
# Ví dụ: https://lyrics-bot.vercel.app
PUBLIC_URL=https://your-app.vercel.app
